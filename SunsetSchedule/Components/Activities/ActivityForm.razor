@using Microsoft.AspNetCore.Components.Forms
@using SunsetSchedule.Models

<EditForm Model="@Model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label>Name</label>
        <InputText class="form-control" @bind-Value="Model.Name" />
    </div>

    <div class="mb-3">
        <label>Description</label>
        <InputTextArea class="form-control" @bind-Value="Model.Description" />
    </div>

    <div class="mb-3">
        <label>Category</label>
        <InputSelect class="form-control" @bind-Value="Model.Category">
            @foreach (var c in Enum.GetValues<ActivityCategory>())
            {
                <option value="@c">@c</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label>Cost</label>
        <InputSelect class="form-control" @bind-Value="Model.Cost">
            @foreach (var c in Enum.GetValues<CostLevel>())
            {
                <option value="@c">@c</option>
            }
        </InputSelect>
    </div>

    <div class="row">
        <div class="col">
            <label>Min Participants</label>
            <InputNumber class="form-control" @bind-Value="Model.MinParticipants" />
        </div>
        <div class="col">
            <label>Max Participants</label>
            <InputNumber class="form-control" @bind-Value="Model.MaxParticipants" />
        </div>
    </div>

    <div class="mb-3 mt-2">
        <label>Time of Day</label>
        <InputSelect class="form-control" @bind-Value="Model.TimeOfDay">
            @foreach (var t in Enum.GetValues<TimeOfDay>())
            {
                <option value="@t">@t</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label>Environment</label>
        <InputSelect class="form-control" @bind-Value="Model.Environment">
            @foreach (var e in Enum.GetValues<ActivityEnvironment>())
            {
                <option value="@e">@e</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label>Weather</label>
        <InputSelect class="form-control" @bind-Value="Model.AllowedWeather">
            @foreach (var w in Enum.GetValues<WeatherType>())
            {
                <option value="@w">@w</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label>Season</label>
        <InputSelect class="form-control" @bind-Value="Model.Season">
            @foreach (var s in Enum.GetValues<Season>())
            {
                <option value="@s">@s</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label>Main Image</label>
        <InputFile OnChange="HandleMainImageUpload" />
    </div>

    <div class="mb-3">
        <label>Gallery Images</label>
        <InputFile OnChange="HandleGalleryUpload" Multiple />
    </div>

    <button class="btn btn-primary" type="submit">
        @ButtonText
    </button>
</EditForm>

@code {
    [Parameter] public Activity Model { get; set; } = new();

    [Parameter] public EventCallback<ActivityFormData> OnSave { get; set; }

    [Parameter] public string ButtonText { get; set; } = "Save";

    private IBrowserFile? uploadedMainImage;
    private IReadOnlyList<IBrowserFile> galleryFiles = new List<IBrowserFile>();

    private void HandleMainImageUpload(InputFileChangeEventArgs e)
    {
        uploadedMainImage = e.File;
    }

    private void HandleGalleryUpload(InputFileChangeEventArgs e)
    {
        galleryFiles = e.GetMultipleFiles();
    }

    private async Task HandleSubmit()
    {
        var formData = new ActivityFormData
        {
            Activity = Model,
            MainImage = uploadedMainImage,
            GalleryImages = galleryFiles
        };

        await OnSave.InvokeAsync(formData);
    }
}