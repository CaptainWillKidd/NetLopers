@using SunsetSchedule.Models

<EditForm Model="@Model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <!-- Activity ID -->
    <div class="mb-3">
        <label class="form-label">Activity Id</label>

        <InputNumber class="form-control" @bind-Value="Model.ActivityId" />
    </div>

    <!-- User ID -->
    <div class="mb-3">
        <label class="form-label">User Id</label>

        <InputText class="form-control" @bind-Value="Model.UserId" />
    </div>

    <!-- Start Time -->
    <div class="mb-3">
        <label class="form-label">Start Time</label>

        <InputDate class="form-control" @bind-Value="Model.StartTime" />
    </div>

    <!-- End Time -->
    <div class="mb-3">
        <label class="form-label">End Time</label>

        <InputDate class="form-control" @bind-Value="Model.EndTime" />
    </div>

    <!-- Notes -->
    <div class="mb-3">
        <label class="form-label">Notes</label>

        <InputTextArea class="form-control" @bind-Value="Model.Notes" />
    </div>

    <button type="submit" class="btn btn-success">
        @ButtonText
    </button>
</EditForm>

@code {
    [Parameter]
    public ScheduledActivity Model { get; set; } = new();

    [Parameter]
    public EventCallback<ScheduledActivity> OnSave { get; set; }

    [Parameter]
    public string ButtonText { get; set; } = "Save";

    private async Task HandleSubmit()
    {
        await OnSave.InvokeAsync(Model);
    }
}