@using SunsetSchedule.Models
@using Microsoft.AspNetCore.Components.Forms

<EditForm Model="@Model" OnSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <!-- Activity ID (hidden) -->
    <input type="hidden" @bind="Model.ActivityId" />

    <!-- Activity Name -->
    <div class="mb-3">
        <label class="form-label">Activity</label>
        <div class="form-control-plaintext">
            @ActivityName
        </div>
    </div>

    <!-- User Name -->
    <div class="mb-3">
        <label class="form-label">User Name</label>
        <InputText class="form-control" @bind-Value="Model.UserId" />
    </div>

    <!-- Start Date -->
    <div class="mb-3">
        <label class="form-label">Start Date</label>
        <InputDate class="form-control" @bind-Value="StartDate" />
    </div>

    <!-- Start Time -->
    <div class="mb-3">
        <label class="form-label">Start Time (HH:mm)</label>
        <InputText class="form-control" @bind-Value="StartTime" placeholder="14:30" />
    </div>

    <!-- End Date -->
    <div class="mb-3">
        <label class="form-label">End Date</label>
        <InputDate class="form-control" @bind-Value="EndDate" />
    </div>

    <!-- End Time -->
    <div class="mb-3">
        <label class="form-label">End Time (HH:mm)</label>
        <InputText class="form-control" @bind-Value="EndTime" placeholder="16:00" />
    </div>

    <!-- Notes -->
    <div class="mb-3">
        <label class="form-label">Notes</label>
        <InputTextArea class="form-control" @bind-Value="Model.Notes" />
        <ValidationMessage For="() => Model.Notes" />
    </div>

    @if (!string.IsNullOrWhiteSpace(ValidationError))
    {
        <div class="alert alert-danger">
            @ValidationError
        </div>
    }

    <button type="submit" class="btn btn-success">
        @ButtonText
    </button>
</EditForm>

@code {

    // ✅ SAFE: non-nullable DateTime (prevents InputDate issues)
    private DateTime StartDate { get; set; } = DateTime.Today;
    private DateTime EndDate { get; set; } = DateTime.Today;

    private string StartTime { get; set; } = "";
    private string EndTime { get; set; } = "";

    private string? ValidationError;

    [Parameter]
    public string? ActivityName { get; set; }

    [Parameter]
    public ScheduledActivity Model { get; set; } = new();

    [Parameter]
    public EventCallback<ScheduledActivity> OnSave { get; set; }

    [Parameter]
    public string ButtonText { get; set; } = "Save";

    private DateTime CombineDateAndTime(DateTime date, string time)
    {
        var parts = time.Split(':');

        var hours = int.Parse(parts[0]);
        var minutes = parts.Length > 1 ? int.Parse(parts[1]) : 0;

        return new DateTime(
            date.Year,
            date.Month,
            date.Day,
            hours,
            minutes,
            0,
            DateTimeKind.Local
        );
    }

    private async Task HandleSubmit()
    {
        Console.WriteLine("HANDLE SUBMIT CALLED");

        ValidationError = null;

        if (string.IsNullOrWhiteSpace(StartTime))
        {
            ValidationError = "Start Time is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(EndTime))
        {
            ValidationError = "End Time is required.";
            return;
        }

        Model.StartTime = CombineDateAndTime(StartDate, StartTime);
        Model.EndTime = CombineDateAndTime(EndDate, EndTime);

        if (Model.StartTime < DateTime.Now)
        {
            ValidationError = "Start time cannot be in the past.";
            return;
        }

        if (Model.EndTime <= Model.StartTime)
        {
            ValidationError = "End time must be after start time.";
            return;
        }

        await OnSave.InvokeAsync(Model);
    }
}