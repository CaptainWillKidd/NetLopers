@page "/randomizer"
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer

@using SunsetSchedule.Models
@using SunsetSchedule.Services
@inject ActivityService ActivityService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider


<div class="container mt-4">
    <h1 class="text-center mb-4">🌅 Random Activity Generator</h1>
    <p class="text-center text-muted mb-4"> Tell us what you're looking for, and we'll suggest the perfect nighttime activity!</p>
    <div class="row">
        <!--filter for column -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">🎯 Define Your Criteria</h5>
                </div>
                <div class="card-body">
                    <EditForm Model="@filterModel" OnValidSubmit="@HandleSubmit" FormName="RandomizerForm">
                        <DataAnnotationsValidator/>
                        <ValidationSummary class="text-danger"/>

                        <!-- Indoor/Outdoor -->
                        <div class="mb-3">
                            <label class="form-label" fw-bold>🏠 Environment</label>
                            <select @bind="filterModel.Environment" class="form-select">
                                <option value="">Any</option>
                                @foreach (var env in Enum.GetValues<ActivityEnvironment>())
                                    {
                                        <option value = "@env">@env</option>
                                    }
                            </select>
                        </div>

                        <!-- Cost -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">💰 Cost Level</label>
                            <select @bind="filterModel.Cost" class="form-select">
                                <option value="">Any</option>
                                @foreach (var cost in Enum.GetValues<CostLevel>())
                                {
                                    <option value="@cost">@cost</option>
                                }
                            </select>
                        </div>

                        <!-- Weather -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">🌤️ Weather Preference</label>
                            <select @bind="filterModel.Weather" class="form-select">
                                <option value="">Any</option>
                                @foreach (var weather in Enum.GetValues<WeatherType>())
                                {
                                    <option value="@weather">@weather</option>
                                }
                            </select>
                        </div>

                        <!-- Time of Day -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">⏰ Time of Day</label>
                            <select @bind="filterModel.TimeOfDay" class="form-select">
                                <option value="">Any</option>
                                @foreach (var time in Enum.GetValues<TimeOfDay>())
                                {
                                    <option value="@time">@time</option>
                                }
                            </select>
                        </div>

                        <!-- Category -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">🎭 Activity Category</label>
                            <select @bind="filterModel.Category" class="form-select">
                                <option value="">Any</option>
                                @foreach (var cat in Enum.GetValues<ActivityCategory>())
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </select>
                        </div>

                        <!-- Season -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">🌸 Season</label>
                            <select @bind="filterModel.Season" class="form-select">
                                <option value="">Any</option>
                                @foreach (var season in Enum.GetValues<Season>())
                                {
                                    <option value="@season">@season</option>
                                }
                            </select>
                        </div>

                        <!-- Group Size -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">👥 Group Size</label>
                            <input type="number" @bind="filterModel.GroupSize" class="form-control" min="1" max="100" />
                            <small class="text-muted">Number of people (1-100)</small>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2" @disabled="isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            🎲 Generate Random Activity
                        </button>
                    </EditForm>
                </div>
            </div>
        </div>

        <!--Results Column-->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">✨ Your Suggested Activity</h5>
                </div>
                <div class="card-body">
                    @if (isLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-3">Finding the perfect activity for you...</p>
                        </div>
                    }
                    else if (randomActivity != null)
                    {
                        <div class="activity-details">
                            <h2 class="text-primary mb-3">@randomActivity.Name</h2>
                            @if (randomActivity.Images.Any())
                            {
                                <img src="@randomActivity.Images.First().ImagePath" 
                                     alt="@randomActivity.Name" 
                                     class="img-fluid rounded mb-3"
                                     style="max-height: 300px; width: 100%; object-fit: cover;" />
                            }

                            <p class="lead">@randomActivity.Description</p>

                            <div class="row mt-4">
                                <div class="col-md-6">
                                    <div class="info-box p-3 bg-light rounded mb-2">
                                        <strong>🏠 Environment:</strong> @randomActivity.Environment
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-box p-3 bg-light rounded mb-2">
                                        <strong>💰 Cost:</strong> @randomActivity.Cost
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-box p-3 bg-light rounded mb-2">
                                        <strong>👥 Group Size:</strong> @randomActivity.MinParticipants - @randomActivity.MaxParticipants people
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-box p-3 bg-light rounded mb-2">
                                        <strong>⏰ Duration:</strong> @randomActivity.DurationMinutes minutes
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-box p-3 bg-light rounded mb-2">
                                        <strong>🌤️ Best Weather:</strong> @randomActivity.AllowedWeather
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="info-box p-3 bg-light rounded mb-2">
                                        <strong>📍 Location:</strong> @(randomActivity.Location ?? "Flexible")
                                    </div>
                                </div>
                            </div>
                            <button class="btn btn-success btn-lg w-100 mt-3" @onclick="() => AddToCalendar(randomActivity)">
                                📅 Add to Calendar
                            </button>
                        </div>
                    } 
                    else if (hasSearched)
                    {
                        <div class="text-center py-5 text-muted">
                            <h3>😕 No Activities Found</h3>
                            <p>@errorMessage</p>
                            <p>Try adjusting your filters and generate again!</p>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <h3>🎯 Ready for Adventure?</h3>
                            <p>Select your preferences and click "Generate Random Activity"</p>
                            <p class="small">We'll suggest the perfect nighttime activity for you!</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .info-box {
        transition: transform 0.2s;
    }
    .info-box:hover {
        transform: translateX(5px);
        background-color: #e9ecef !important;
    }
    .activity-details h2 {
        border-left: 4px solid #0d6efd;
        padding-left: 15px;
    }
</style>

@code {
    private bool _authChecked = false;
    private FilterModel filterModel = new();
    private Activity? randomActivity;
    private bool isLoading = false;
    private bool hasSearched = false;
    private string errorMessage = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _authChecked) return;

        _authChecked = true;

        var auth = await AuthProvider.GetAuthenticationStateAsync();

        if (auth.User.Identity?.IsAuthenticated != true)
        {
            var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
            Navigation.NavigateTo($"/login?returnUrl={returnUrl}", forceLoad: true);
            return;
        }

        // Only load data after authentication is confirmed
        // Your existing initialization code here
        
        StateHasChanged();
    }

    private async Task HandleSubmit()
    {
        isLoading = true;
        hasSearched = true;
        randomActivity = null;
        StateHasChanged();

        try
        {
            var (activity, message) = await ActivityService.GetRandomActivityWithMessageAsync(
                environment: filterModel.Environment,
                cost: filterModel.Cost,
                weather: filterModel.Weather,
                timeOfDay: filterModel.TimeOfDay,
                category: filterModel.Category,
                season: filterModel.Season,
                groupSize: filterModel.GroupSize > 0 ? filterModel.GroupSize : null
            );

            randomActivity = activity;
            errorMessage = message;
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
            randomActivity = null;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task AddToCalendar(Activity activity)
    {
        // This will integrate with Google Calendar API
        // For now, show a success message
        Console.WriteLine($"Adding {activity.Name} to calendar...");
        
        // TODO: Implement Google Calendar integration
        // You can show a temporary message using a snackbar or alert
    }
}