@page "/activities"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]



@using SunsetSchedule.Components.Shared
@inject ActivityService ActivityService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<h2>Activities</h2>

<Alert Message="@errorMessage" Type="AlertType.Error" />

@if (activities is null)
{
    <p>Loading...</p>
}
else if (!activities.Any())
{
    <p>No activities found.</p>
}
else
{
    <div class="activities-grid">
    @foreach (var a in activities)
    {
        var img = a.Images?.FirstOrDefault()?.ImagePath ?? "/images/default-activity.webp";

        <div
            class="activity-item">

            <!-- Thumbnail -->
            <img src="@img" class="activity-image" />

            <!-- Content -->
            <div class='activity-content'>
                <button class="activity-name" @onclick="() => ViewDetails(a.Id)">
                    @a.Name
                </button>
            </div>

            <!-- Actions -->
            <div class="activity-buttons">
                <button class="btn btn-primary btn-sm" @onclick="() => Edit(a.Id)">
                    Edit
                </button>

                <button class="btn btn-danger btn-sm" @onclick="() => Delete(a.Id)">
                    Delete
                </button>
            </div>

        </div>
    
    }
    </div>
}

@code {
    
    private List<Activity>? activities;

    private string? errorMessage;
    protected override async Task OnInitializedAsync()
    {
        activities = await ActivityService.GetAllAsync();
    }

    private void Edit(int id)
    {
        Navigation.NavigateTo($"/activities/edit/{id}");
    }

    private async Task Delete(int id)
    {
        errorMessage = null;

        var scheduledCount = await ActivityService.GetScheduledCountAsync(id);

        if (scheduledCount > 0)
        {
            var confirmed = await JS.InvokeAsync<bool>(
                "confirm",
                $"This activity has {scheduledCount} scheduled entries. Deleting it will also remove them. Continue?"
            );

            if (!confirmed)
                return;
        }

        var result = await ActivityService.DeleteAsync(id);

        if (!result.Success)
        {
            errorMessage = result.Error;
            return;
        }

        activities = await ActivityService.GetAllAsync();
    }

    private void ViewDetails(int id)
    {
        Navigation.NavigateTo($"/activities/details/{id}");
    }
}