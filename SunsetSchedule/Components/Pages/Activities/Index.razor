@page "/activities"
@rendermode InteractiveServer
@inject ActivityService ActivityService
@inject NavigationManager Navigation

<h3>Activities</h3>

@if (activities is null)
{
    <p>Loading...</p>
}
else
{
    @foreach (var a in activities)
    {
        <div class="mb-2">
            <strong>@a.Name</strong>

            <button class="btn btn-primary ms-2" @onclick="() => Edit(a.Id)">
                Edit
            </button>

            <button class="btn btn-danger ms-2" @onclick="() => Delete(a.Id)">
                Delete
            </button>
        </div>
    }
}

@code {
    private List<Activity>? activities;

    protected override async Task OnInitializedAsync()
    {
        activities = await ActivityService.GetAllAsync();
    }

    private void Edit(int id)
    {
        Navigation.NavigateTo($"/activities/edit/{id}");
    }

    private async Task Delete(int id)
    {
        await ActivityService.DeleteAsync(id);
        activities = await ActivityService.GetAllAsync();
    }
}