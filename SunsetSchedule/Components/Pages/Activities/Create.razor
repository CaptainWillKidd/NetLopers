@page "/activities/create"
@using Microsoft.AspNetCore.Components.Authorization

@rendermode InteractiveServer

@inject ActivityService ActivityService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

<h3>Create Activity</h3>

<Alert Message="@errorMessage" Type="AlertType.Error" />

<ActivityForm Model="@activity" OnSave="CreateActivity" ButtonText="Create" />

@code {
    private Activity activity = new();
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var auth = await AuthProvider.GetAuthenticationStateAsync();

        if (auth.User.Identity?.IsAuthenticated != true)
        {
            var returnUrl = Nav.ToBaseRelativePath(Nav.Uri);
            Nav.NavigateTo($"/login?returnUrl={returnUrl}");
            return;
        }
    }

    private async Task CreateActivity(Activity activity)
    {
        var result = await ActivityService.CreateAsync(activity);

        if (!result.Success)
        {
            errorMessage = result.Error;
            return;
        }

        Nav.NavigateTo("/activities");
    }
}