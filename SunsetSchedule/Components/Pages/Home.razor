@page "/"

<PageTitle>Home - Sunset Scheduler</PageTitle>

<div class="container mt-4">
    <!-- Hero Section -->
    <div class="text-center mb-5 p-5 text-white rounded hero-section">
        <h1 class="display-4">🌅 Welcome to Sunset Scheduler</h1>
        <p class="lead">Discover, plan, and enjoy unforgettable nighttime activities</p>
        <div class="mt-4">
            <NavLink class="btn btn-light btn-lg me-2" href="/randomizer">
                🎲 Find Random Activity
            </NavLink>
            <NavLink class="btn btn-outline-light btn-lg me-2" href="/activities">
                📋 Browse Activities
            </NavLink>
            <NavLink class="btn btn-outline-light btn-lg" href="/scheduledactivities">
                📅 My Schedule
            </NavLink>
        </div>
    </div>

    <!-- How It Works -->
    <h2 class="text-center mb-4 section-title">How It Works</h2>
    <div class="row text-center mb-5">
        <div class="col-md-4">
            <NavLink class="card h-100 shadow-sm text-decoration-none" href="/randomizer">
                <div class="card-body">
                    <div class="display-1">🎯</div>
                    <h3 class="card-title h4 mt-3">1. Choose Filters</h3>
                    <p class="card-text">Select your preferences: indoor/outdoor, cost, weather, and group size.</p>
                </div>
            </NavLink>
        </div>
        <div class="col-md-4">
            <NavLink class="card h-100 shadow-sm text-decoration-none" href="/randomizer">
                <div class="card-body">
                    <div class="display-1">✨</div>
                    <h3 class="card-title h4 mt-3">2. Get Suggestions</h3>
                    <p class="card-text">We'll find the perfect random activity that matches your criteria.</p>
                </div>
            </NavLink>
        </div>
        <div class="col-md-4">
            <NavLink class="card h-100 shadow-sm text-decoration-none" href="/scheduledactivities">
                <div class="card-body">
                    <div class="display-1">📅</div>
                    <h3 class="card-title h4 mt-3">3. Save to Calendar</h3>
                    <p class="card-text">Add activities directly to your schedule and never miss out.</p>
                </div>
            </NavLink>
        </div>
    </div>

    <!-- Popular Activities -->
    <h2 class="text-center mb-4 section-title">🌟 Popular Activities</h2>
    <div class="row mb-5">
        <div class="col-md-4 mb-3">
            <NavLink class="card h-100 shadow-sm text-decoration-none" href="/activities">
                <div class="card-body text-center">
                    <div class="display-4">🥾</div>
                    <h4>Hike Bridal Veil Falls</h4>
                    <p>Provo Canyon • Outdoor</p>
                    <span class="badge cost-free">Free</span>
                </div>
            </NavLink>
        </div>
        <div class="col-md-4 mb-3">
            <NavLink class="card h-100 shadow-sm text-decoration-none" href="/activities">
                <div class="card-body text-center">
                    <div class="display-4">🎲</div>
                    <h4>Board Game Night</h4>
                    <p>Indoor • Social</p>
                    <span class="badge cost-low">Low cost</span>
                </div>
            </NavLink>
        </div>
        <div class="col-md-4 mb-3">
            <NavLink class="card h-100 shadow-sm text-decoration-none" href="/activities">
                <div class="card-body text-center">
                    <div class="display-4">🏛️</div>
                    <h4>Thanksgiving Point</h4>
                    <p>Lehi • Entertainment</p>
                    <span class="badge cost-medium">Medium</span>
                </div>
            </NavLink>
        </div>
    </div>

    <!-- Call to Action -->
    <div class="text-center p-5 rounded cta-section">
        <h2>Ready for Your Next Adventure?</h2>
        <p>Get personalized activity suggestions based on your preferences</p>
        <NavLink class="btn btn-cta btn-lg" href="/randomizer">
            🚀 Get Started Now
        </NavLink>
    </div>
</div>

<style>
    /* Color Theme Variables */
    :root {
        --primary-red: #D9525E;
        --primary-purple-dark: #6503A6;
        --primary-purple-deep: #3C0673;
        --primary-purple-darker: #211159;
        --background-light: #F2F2F2;
    }

    /* Hero Section */
    .hero-section {
        background: linear-gradient(135deg, var(--primary-purple-dark) 0%, var(--primary-purple-deep) 100%);
    }

    /* Section Titles */
    .section-title {
        color: var(--primary-purple-darker);
        font-weight: 600;
    }

    /* Cards */
    .card {
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
        border: 1px solid rgba(0,0,0,0.1);
    }
    
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }

    .text-decoration-none {
        text-decoration: none;
    }

    .card h3, .card h4 {
        color: var(--primary-purple-darker);
    }

    .card p {
        color: #555;
    }

    /* Badge Colors */
    .cost-free {
        background-color: #28a745;
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 0.25rem;
        font-size: 0.75rem;
    }

    .cost-low {
        background-color: #17a2b8;
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 0.25rem;
        font-size: 0.75rem;
    }

    .cost-medium {
        background-color: #ffc107;
        color: #333;
        padding: 0.25rem 0.75rem;
        border-radius: 0.25rem;
        font-size: 0.75rem;
    }

    /* Call to Action Section */
    .cta-section {
        background: linear-gradient(135deg, var(--primary-purple-deep) 0%, var(--primary-purple-darker) 100%);
        color: white;
    }

    .btn-cta {
        background-color: var(--primary-red);
        border: none;
        color: white;
        font-weight: 600;
        padding: 0.75rem 2rem;
    }

    .btn-cta:hover {
        background-color: #c44550;
        color: white;
        transform: scale(1.05);
    }

    /* Button Overrides */
    .btn-light {
        background-color: var(--background-light);
        border: none;
        color: var(--primary-purple-darker);
    }

    .btn-light:hover {
        background-color: #e5e5e5;
        color: var(--primary-purple-darker);
    }

    .btn-outline-light {
        border: 2px solid white;
        color: white;
    }

    .btn-outline-light:hover {
        background-color: white;
        color: var(--primary-purple-dark);
    }
</style>