@page "/scheduledactivities/edit/{Id:int}"
@using Microsoft.AspNetCore.Components.Authorization

@rendermode InteractiveServer
@inject ScheduledActivityService ScheduledActivityService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider

<h3>Edit Scheduled Activity</h3>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">
        @ErrorMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(SuccessMessage))
{
    <div class="alert alert-success">
        @SuccessMessage
    </div>
}

@if (scheduledActivity is null)
{
    <p>Loading...</p>
}
else
{
    <ScheduledActivityForm Model="@scheduledActivity" OnSave="UpdateScheduledActivity" ButtonText="Update" />
}

@code {
    [Parameter] public int Id { get; set; }

    private ScheduledActivity? scheduledActivity;

    private string? ErrorMessage;
    private string? SuccessMessage;

    private bool _authChecked = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _authChecked) return;

        _authChecked = true;

        var auth = await AuthProvider.GetAuthenticationStateAsync();

        if (auth.User.Identity?.IsAuthenticated != true)
        {
            var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
            Navigation.NavigateTo($"/login?returnUrl={returnUrl}", forceLoad: true);
            return;
        }

        try
        {
            scheduledActivity = await ScheduledActivityService.GetByIdAsync(Id);

            if (scheduledActivity is null)
            {
                ErrorMessage = "Scheduled activity not found.";
                return;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Failed to load scheduled activity.";
            Console.WriteLine(ex.Message);
        }

        StateHasChanged();
    }

    private async Task UpdateScheduledActivity(ScheduledActivity a)
    {
        try
        {
            ErrorMessage = null;
            SuccessMessage = null;

            await ScheduledActivityService.UpdateAsync(a);

            SuccessMessage = "Scheduled activity updated successfully.";

            await Task.Delay(300);

            Navigation.NavigateTo("/scheduledactivities");
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            Console.WriteLine(ex);
        }
    }
}