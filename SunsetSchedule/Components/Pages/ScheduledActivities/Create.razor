@page "/scheduledactivities/create/{ActivityId:int}"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components

@rendermode InteractiveServer

@inject ScheduledActivityService ScheduledActivityService
@inject ActivityService ActivityService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

@if (activityName is null)
{
    <h2>Schedule Activity</h2>
}
else
{
    <h2>Schedule: @activityName</h2>
}

<ScheduledActivityForm 
    Model="@scheduledActivity" 
    ActivityName="@activityName" 
    OnSave="CreateScheduledActivity"
    ButtonText="Create" />

@code {
    [Parameter]
    public int ActivityId { get; set; }
    private ScheduledActivity scheduledActivity = new();

    private string? activityName;

    private bool _authChecked = false;

    protected override void OnInitialized()
    {
        scheduledActivity.StartTime = DateTime.Now;
        scheduledActivity.EndTime = DateTime.Now.AddHours(1);
    }

    protected override async Task OnParametersSetAsync()
    {
        var activity = await ActivityService.GetByIdAsync(ActivityId);

        activityName = activity?.Name ?? "Unknown Activity";

        scheduledActivity.ActivityId = ActivityId;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _authChecked) return;

        _authChecked = true;

        var auth = await AuthProvider.GetAuthenticationStateAsync();

        if (auth.User.Identity?.IsAuthenticated != true)
        {
            var returnUrl = Nav.ToBaseRelativePath(Nav.Uri);
            Nav.NavigateTo($"/login?returnUrl={returnUrl}", forceLoad: true);
            return;
        }

        StateHasChanged();
    }

    private async Task CreateScheduledActivity(ScheduledActivity a)
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();

        if (auth.User.Identity?.IsAuthenticated != true)
        {
            var returnUrl = Nav.ToBaseRelativePath(Nav.Uri);
            Nav.NavigateTo($"/login?returnUrl={returnUrl}", forceLoad: true);
            return;
        }

        await ScheduledActivityService.CreateAsync(a);

        Nav.NavigateTo("/scheduledactivities");
    }
}