@using Microsoft.AspNetCore.Components.Authorization
@using SunsetSchedule.Components
@using SunsetSchedule.Models
@inject AuthStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@implements IAsyncDisposable
@rendermode InteractiveServer

@if (CurrentUser != null)
{
    <div class="ms-auto d-flex align-items-center gap-3">
        <div class="user-profile">
            <span class="user-name">@CurrentUser.Username</span>
            <small class="user-email d-block">@CurrentUser.Email</small>
        </div>
        <button class="btn btn-outline-light btn-sm" @onclick="HandleLogout">
            <span class="bi bi-box-arrow-right"></span> Logout
        </button>
    </div>
}
else
{
    <div class="ms-auto d-flex gap-2">
        <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
        <a href="/register" class="btn btn-light btn-sm">Register</a>
    </div>
}

@code {
    private User? CurrentUser;

    protected override async Task OnInitializedAsync()
    {
        CurrentUser = await AuthStateProvider.GetCurrentUserAsync();
        AuthStateProvider.OnUserChanged += UpdateUser;
    }

    private void UpdateUser()
    {
        Task.Run(async () =>
        {
            CurrentUser = await AuthStateProvider.GetCurrentUserAsync();
            await InvokeAsync(StateHasChanged);
        });
    }

    ValueTask IAsyncDisposable.DisposeAsync()
    {
        AuthStateProvider.OnUserChanged -= UpdateUser;
        return ValueTask.CompletedTask;
    }

    private async Task HandleLogout()
    {
        await AuthStateProvider.LogoutAsync();
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }
}
